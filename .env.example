# Permian Auto Works — booking POC. Copy this file to .env.local and fill in.
# Never commit .env.local (it is gitignored).

# ─── Database (required) ──────────────────────────────────────────────────────
# Neon POOLED Postgres connection string (host contains `-pooler`, sslmode=require).
# Copy from the Neon console, or `get_connection_string`. Used by both the app's
# @neondatabase/serverless client (lib/db.ts) and Better Auth's pool (lib/auth.ts).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── Admin auth — Better Auth (required for /admin) ───────────────────────────
# A long random string used to sign sessions/cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"
# The app's public origin. In dev this is http://localhost:3000; in prod set it to
# the deployed origin (e.g. https://permian-auto.vercel.app).
BETTER_AUTH_URL="http://localhost:3000"
# The single owner/admin account. Seeded automatically on first admin login attempt
# (see lib/auth.ts). Use a real address + a strong password for the demo.
ADMIN_EMAIL="owner@permianautoworks.example"
ADMIN_PASSWORD="change-me-strong-password"

# ─── Errors — Sentry (optional) ───────────────────────────────────────────────
# If unset, Sentry is disabled and every capture call is a no-op. The expected
# double-booking conflict is NEVER sent here — only unexpected failures are.
# SENTRY_DSN="https://...ingest.sentry.io/..."

# ─── Misc (optional) ──────────────────────────────────────────────────────────
# Exact public origin, if you want it pinned (otherwise derived from the request).
# PUBLIC_BASE_URL="https://permian-auto.vercel.app"

# ─── Post-booking lifecycle (Phase 5+) ────────────────────────────────────────
# Email via Resend. Without a key, email sends are skipped (logged, no-op).
# RESEND_API_KEY="re_..."
# From header for emails. Use a Resend-verified domain in production; the default
# onboarding sender only delivers to the Resend account owner.
# RESEND_FROM="Permian Auto Works <bookings@yourdomain.com>"

# SMS via Twilio (same account as the missed-call tool). Without all three, SMS
# sends are skipped (logged, no-op) — wiring them on is just adding the keys.
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_NUMBER="+1..."

# How many hours before the appointment the reminder fires. Default 24.
# REMINDER_LEAD_HOURS="24"

# Inngest (durable functions). NOT needed in local dev — run `npx inngest-cli dev`
# and the client auto-uses the local Dev Server. REQUIRED in production (cloud
# mode): copy both from the Inngest dashboard after connecting your Vercel app.
# INNGEST_EVENT_KEY="..."
# INNGEST_SIGNING_KEY="signkey-..."
